# Backend env (Railway). Copy to backend/.env for local dev. NEVER commit real values.

# ── Server ───────────────────────────────────────────────
# Railway injects PORT automatically — do NOT hardcode it in production.
PORT=4000
# CORS allowlist: the exact frontend origin(s), scheme+host, NO trailing slash.
# Comma-separate multiple (e.g. prod + a custom domain). Set to your Vercel URL.
FRONTEND_URL=http://localhost:5173

# ── Supabase (service role — backend only, NEVER expose to the client) ──
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Groq (AI chat — OpenAI-compatible) ───────────────────
# Primary + optional backup keys; chat fails over to the next when one is
# rate-limited or out of free quota.
GROQ_API_KEY=
GROQ_API_KEY_2=
GROQ_MODEL=llama-3.3-70b-versatile

# ── Twilio (SOS SMS — optional; SOS still works without it) ──
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# All external services degrade gracefully if unset (see backend/test/audit.js).
