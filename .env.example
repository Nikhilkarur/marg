# Frontend env (Vercel). Copy to .env for local dev. Only VITE_* vars are exposed
# to the browser — NEVER put a service_role key or any backend secret here.

# Backend base URL. In production set this to your Railway backend URL (HTTPS),
# e.g. https://marg-backend.up.railway.app  (no trailing slash).
VITE_BACKEND_URL=http://localhost:4000

# Supabase (client-safe anon key only). Leave blank to use built-in demo auth.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
